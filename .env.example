# .env.example — copy to .env.local and fill in your SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourpassword
CONTACT_TO=info@cartrade24.ch

# AutoScout24 Dealer API
AS24_API_KEY=your_api_key_here
AS24_DEALER_ID=your_dealer_id_here

# Tracking & Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Matelso
NEXT_PUBLIC_MATELSO_ID=your_matelso_id
NEXT_PUBLIC_MATELSO_BOOKING_URL=

# Anthropic (KI-Verkäufertext auf Fahrzeug-Detailseiten)
ANTHROPIC_API_KEY=sk-ant-...
